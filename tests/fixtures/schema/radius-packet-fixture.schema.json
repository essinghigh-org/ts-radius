{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://essinghigh-org.github.io/ts-radius/tests/fixtures/schema/radius-packet-fixture.schema.json",
  "title": "Radius Packet Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "rfc",
    "description",
    "packetHex",
    "expected"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "rfc": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "packetHex": {
      "type": "string",
      "minLength": 1
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "identifier",
        "length",
        "authenticatorHexPattern",
        "attributes"
      ],
      "properties": {
        "code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "identifier": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "length": {
          "type": "integer",
          "minimum": 20,
          "maximum": 4096
        },
        "authenticatorHexPattern": {
          "type": "string",
          "minLength": 1
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "rawHex",
              "decodedValue"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "rawHex": {
                "type": "string",
                "minLength": 1
              },
              "decodedValue": {}
            }
          }
        }
      }
